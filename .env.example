# Trivia Risk: Margin of Error — server configuration
#
# Copy this file to `.env` and fill in your Anthropic API key.
# The key is ONLY ever read server-side; it is never sent to the browser.

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Optional: model used to generate trivia questions. Defaults to claude-opus-4-8.
# Override with a faster/cheaper model if you prefer, e.g. claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional: HTTP port (default 4318).
PORT=4318

# Developer-only escape hatch. Leave disabled (false) for normal play.
# When true, if Anthropic generation fails after retries the server returns a
# clearly-marked TEST-ONLY fallback question instead of an error. Off by default.
ALLOW_FALLBACK_QUESTIONS=false
